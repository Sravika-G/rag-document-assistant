# Google Gemini API Key (Get yours from Google AI Studio)
GEMINI_API_KEY=""

# JWT Secret Key for Session Token signing
JWT_SECRET=""

# Production Database URL (PostgreSQL)
# e.g., postgresql://username:password@hostname:5432/dbname?sslmode=require
# If left empty, the server defaults to a local SQLite file (database.sqlite) for ease of development.
DATABASE_URL=""

# Node environment (production or development)
NODE_ENV="development"
