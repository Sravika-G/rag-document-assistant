# Google Gemini API Key (Get yours from Google AI Studio)
GEMINI_API_KEY=""

# JWT Secret Key for Session Token signing (Use a complex random string in production)
JWT_SECRET=""

# Production Database URL for durable persistent storage (PostgreSQL)
# e.g., postgresql://username:password@hostname:5432/dbname?sslmode=require
# Note: If left empty, the server fallback is local ephemeral SQLite (database.sqlite), which resets on cloud deployment restarts.
DATABASE_URL=""

# Node environment (production or development)
NODE_ENV="development"
